# Environment Configuration

# Network Mode (set to 'true' for testnet, 'false' for mainnet)
VITE_USE_TESTNET=false

# Reown AppKit Project ID
VITE_REOWN_PROJECT_ID=

# Optional: Block Explorer API Keys (for better transaction history)
# Get free API keys from:
# - Etherscan: https://etherscan.io/apis
# - Polygonscan: https://polygonscan.com/apis
# - BscScan: https://bscscan.com/apis
# Note: The app works without these keys but with rate limits
VITE_ETHERSCAN_API_KEY=
VITE_POLYGONSCAN_API_KEY=
VITE_BSCSCAN_API_KEY=

# Backend API URL (provide the URL of your deployed backend)
VITE_BACKEND_API_URL=
